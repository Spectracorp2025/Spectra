rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'carlosdelgado.neska@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_admin == true
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Helpers for specific collections
    function isValidUserProfile(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'rank', 'is_admin', 'created_at'])
        && data.id == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.phone is string && data.phone.size() >= 5 && data.phone.size() <= 20
        && data.rank in ['Normal', 'Premium', 'Plus']
        && (data.age == null || data.age is int)
        && (data.country == null || data.country is string)
        && (data.email == null || data.email is string)
        && data.is_admin is bool
        && data.created_at is timestamp;
    }

    // Admins Whitelist
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or service account
    }

    // Health Check
    match /system/status {
      allow read: if isSignedIn();
    }

    // User Profiles
    match /profiles/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isSignedIn() && (
        (isOwner(userId) && isValidUserProfile(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'age', 'country', 'phone', 'email']))
        || isAdmin()
      );
    }

    // Content Collections (Publicly readable by auth users, Admin only write)
    match /products/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /games/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /tools/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /networks/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /shared_accounts/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /plans/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /reports/{id} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /novels/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /chapters/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /streams/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /forums/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
        allow delete: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      }

      match /likes/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && userId == request.auth.uid;
      }
    }
  }
}
